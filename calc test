import tkinter as tk
from tkinter import messagebox
import matplotlib.pyplot as plt


def calculate():
    try:
        principal = float(principal_entry.get())
        rate = float(rate_entry.get()) / 100
        days = int(days_entry.get())

        values = []

        for day in range(days + 1):
            amount = principal * (1 + rate / 365) ** day
            values.append(amount)

        final_amount = values[-1]
        interest_earned = final_amount - principal

        result_label.config(
            text=(
                f"Final amount: £{final_amount:.2f}\n"
                f"Interest earned: £{interest_earned:.2f}"
            )
        )

        plt.plot(range(days + 1), values)
        plt.xlabel("Days")
        plt.ylabel("Amount (£)")
        plt.title("Daily Compounding")
        plt.xticks(range(0, days + 1, max(1, days // 10)))
        plt.grid(True)
        plt.ticklabel_format(style='plain', axis='y')
        plt.show()

    except ValueError:
        messagebox.showerror("Input error", "Please enter valid numbers.")


root = tk.Tk()
root.title("Daily Interest Compounder")
root.geometry("350x250")

tk.Label(root, text="Starting amount (£)").pack()
principal_entry = tk.Entry(root)
principal_entry.pack()
principal_entry.insert(0, "33472.33")

tk.Label(root, text="Annual interest rate (%)").pack()
rate_entry = tk.Entry(root)
rate_entry.pack()
rate_entry.insert(0, "3.6")

tk.Label(root, text="Number of days").pack()
days_entry = tk.Entry(root)
days_entry.pack()
days_entry.insert(0, "365")

tk.Button(root, text="Calculate and Show Graph", command=calculate).pack(pady=10)

result_label = tk.Label(root, text="", justify="left")
result_label.pack()

root.mainloop()